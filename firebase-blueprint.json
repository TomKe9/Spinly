{
  "entities": {
    "booking": {
      "title": "Booking",
      "description": "Zákaznická rezervace termínu ve službě.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unikátní ID rezervace." },
        "service": { "type": "string", "description": "Název vybrané služby." },
        "day": { "type": "string", "description": "Datum nebo den rezervace (např. Dnes, Zítra, konkrétní datum)." },
        "time": { "type": "string", "description": "Čas termínu (např. 14:00)." },
        "clientName": { "type": "string", "description": "Jméno a příjmení klienta." },
        "clientPhone": { "type": "string", "description": "Telefonní číslo pro zaslání SMS." },
        "clientEmail": { "type": "string", "description": "Nepovinný kontaktní e-mail klienta." },
        "status": { "type": "string", "enum": ["přijato", "potvrzeno", "stornováno", "hotovo"], "description": "Aktuální stav rezervace." },
        "industry": { "type": "string", "description": "Kategorie podniku (salon, hair, massage, physio, other)." },
        "businessId": { "type": "string", "description": "Identifikátor obchodníka (uid), ke kterému rezervace patří." },
        "note": { "type": "string", "description": "Interní poznámka k návštěvě pro obchodníka." },
        "createdAt": { "type": "string", "format": "date-time", "description": "Čas vytvoření rezervace." }
      },
      "required": ["service", "day", "time", "clientName", "clientPhone", "status", "industry", "createdAt"]
    },
    "service": {
      "title": "Service",
      "description": "Nabízená služba daného salonu nebo živnostníka.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unikátní ID služby." },
        "name": { "type": "string", "description": "Název služby." },
        "price": { "type": "number", "description": "Cena služby v Kč." },
        "duration": { "type": "number", "description": "Doba trvání v minutách." },
        "businessId": { "type": "string", "description": "Identifikátor obchodníka (uid), který službu nabízí." },
        "createdAt": { "type": "string", "format": "date-time", "description": "Čas vytvoření služby." }
      },
      "required": ["name", "price", "duration", "businessId", "createdAt"]
    },
    "businessProfile": {
      "title": "BusinessProfile",
      "description": "Podrobný profil podniku, kontaktní údaje a nastavení pracovní doby.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "UID obchodníka z Firebase Auth." },
        "businessName": { "type": "string", "description": "Obchodní jméno podniku / salonu." },
        "ownerName": { "type": "string", "description": "Celé jméno majitele." },
        "email": { "type": "string", "format": "email", "description": "Kontaktní e-mail." },
        "phone": { "type": "string", "description": "Telefonní číslo podniku." },
        "industry": { "type": "string", "description": "Obor podnikání (salon, hair, massage, physio, other)." },
        "startHour": { "type": "string", "description": "Počáteční pracovní hodina (např. 08:00)." },
        "endHour": { "type": "string", "description": "Koncová pracovní hodina (např. 18:00)." },
        "createdAt": { "type": "string", "format": "date-time", "description": "Čas vytvoření profilu." }
      },
      "required": ["businessName", "ownerName", "email", "phone", "industry", "createdAt"]
    },
    "lead": {
      "title": "Lead",
      "description": "Registrace zkušebního účtu majitele salonu / podniku.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unikátní ID leadu." },
        "businessName": { "type": "string", "description": "Název podniku." },
        "segment": { "type": "string", "description": "Obor podnikání." },
        "name": { "type": "string", "description": "Celé jméno majitele." },
        "email": { "type": "string", "format": "email", "description": "Kontaktní e-mail." },
        "phone": { "type": "string", "description": "Kontaktní telefon." },
        "plan": { "type": "string", "description": "Zvolený tarif (Zdarma, Pro, Enterprise)." },
        "walletBalance": { "type": "number", "description": "Aktuální zůstatek peněženky uživatele v Kč (výchozí 1000 Kč jako bonus)." },
        "createdAt": { "type": "string", "format": "date-time", "description": "Čas registrace." }
      },
      "required": ["businessName", "segment", "name", "email", "phone", "plan", "createdAt"]
    },
    "walletTransaction": {
      "title": "WalletTransaction",
      "description": "Záznam o transakci v peněžence (dobití nebo platba kadeřníkovi/barberovi).",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unikátní ID transakce." },
        "userId": { "type": "string", "description": "ID uživatele, kterému transakce patří." },
        "userEmail": { "type": "string", "description": "E-mail uživatele." },
        "type": { "type": "string", "enum": ["topup", "payment_sent", "payment_received"], "description": "Typ transakce." },
        "amount": { "type": "number", "description": "Částka transakce v Kč." },
        "description": { "type": "string", "description": "Slovní popis (např. 'Dobití peněženky', 'Platba za Pánský střih')." },
        "targetUid": { "type": "string", "description": "Cílové ID (obchodník při platbě, nebo plátce při příjmu)." },
        "targetName": { "type": "string", "description": "Název protistrany (např. salonu)." },
        "bookingId": { "type": "string", "description": "Případné ID spojené rezervace." },
        "createdAt": { "type": "string", "format": "date-time", "description": "Čas provedení transakce." }
      },
      "required": ["id", "userId", "type", "amount", "description", "createdAt"]
    }
  },
  "firestore": {
    "/bookings/{bookingId}": {
      "schema": "booking",
      "description": "Kolekce pro všechny klientské rezervace termínů."
    },
    "/services/{serviceId}": {
      "schema": "service",
      "description": "Kolekce pro nabízené služby jednotlivých obchodníků."
    },
    "/businessProfiles/{profileId}": {
      "schema": "businessProfile",
      "description": "Kolekce pro profily a nastavení jednotlivých obchodníků."
    },
    "/leads/{leadId}": {
      "schema": "lead",
      "description": "Kolekce pro zkušební registrace partnerů do systému Spinly."
    },
    "/walletTransactions/{transactionId}": {
      "schema": "walletTransaction",
      "description": "Kolekce všech finančních převodů a dobití v systému."
    }
  }
}
